{
    "Title": "Rigorous RAG Evaluation - Dual Testing Methodology",
    "Description": "Each question tested twice: without RAG (LLM knowledge) then with RAG (corpus). Measures when RAG is truly required vs when LLM already knows the answer.",
    "Methodology": {
        "Approach": "Provenance-first RAG with smart fallback",
        "Categories": {
            "RAG-SUFFICIENT": "Retrieved context (>0.7 similarity) was good enough to answer correctly - pure corpus knowledge",
            "LLM-KNOWLEDGE": "No relevant context found (<0.7 similarity) - LLM answered from pretrained knowledge",
            "LLM-RESCUED": "Retrieved context led to wrong answer - LLM fallback succeeded (corpus lacks specific data)",
            "NO-CONTEXT": "No relevant context found - LLM also failed (needs corpus expansion)",
            "BOTH-FAILED": "Had context but both RAG and LLM failed (question too hard)"
        },
        "Similarity Threshold": 0.7,
        "Rationale": "0.7 threshold based on scientific/biomedical RAG standards for high-precision reference-confident systems",
        "Top-K Retrieval": 5,
        "Corrupted Text Filtering": "Enabled"
    },
